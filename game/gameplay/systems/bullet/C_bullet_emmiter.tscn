[sub_resource type="GDScript" id="GDScript_t4dbo"]
script/source = "extends Marker3D


@export var shoot_audio_stream: AudioStream
@export var shoot_audio_pitch_scale: float = 1.0

@onready var hit_ray_cast: RayCast3D = $HitRayCast
@onready var bullets_pool_manager: ObjectPoolManager = $ObjectPoolManager
#@onready var muzzle_flash: Node3D = $MuzzleFlash
@onready var shoot_audio: AudioStreamPlayer3D = $ShootAudio


func shoot(attack_data: AttackData = null) -> void:
	if not attack_data:
		attack_data = AttackData.new()
		attack_data.from_position = global_position
	
	#global_basis = Basis(Quaternion(Vector3.FORWARD, global_position.direction_to(attack_data.target_position)))
	
	var target: Vector3
	if attack_data.target_position: target = attack_data.target_position
	else: target = to_global(hit_ray_cast.target_position)
	
	hit_ray_cast.target_position = to_local(target)
	hit_ray_cast.hit(attack_data)
	bullets_pool_manager.pool_create_object(global_position, target)
	
	#muzzle_flash.emit()
	
	shoot_audio.stream = shoot_audio_stream
	shoot_audio.pitch_scale = shoot_audio_pitch_scale
	shoot_audio.play()
"

[node name="BulletEmmiter" type="Marker3D" unique_id=1799333098]
script = SubResource("GDScript_t4dbo")

