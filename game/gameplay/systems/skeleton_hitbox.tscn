[sub_resource type="GDScript" id="GDScript_u20ry"]
script/source = "@tool
extends Node3D


@export var health_comp: HealthComponent: set = set_health_comp
@export var skeleton: Skeleton3D: set = set_skeleton
@onready var attachments: Node3D = $Attachments
@onready var hitbox: Hitbox = $Hitbox


func set_health_comp(comp: HealthComponent) -> void:
	if not is_node_ready(): await ready
	if Engine.is_editor_hint():
		health_comp = comp
		hitbox.health_comp = comp
func set_skeleton(value: Skeleton3D) -> void:
	if not is_node_ready(): await ready
	if Engine.is_editor_hint():
		skeleton = value
	
		var path: NodePath = ^''
		if skeleton: path = get_path_to(skeleton)
		
		for n in attachments.get_children():
			if n is BoneAttachment3D:
				if skeleton:
					n.external_skeleton = path
"

